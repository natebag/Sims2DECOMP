/* Sims 2 GameCube (G4ZE69) — GNU LD linker script
 *
 * Places sections at the exact virtual addresses found in the
 * original DOL/ELF (u2_ngc_release_dvd.elf).
 *
 * Section addresses extracted from:
 *   readelf -S extracted/files/u2_ngc_release_dvd.elf
 *
 * SDA base registers extracted from __start (0x80003100):
 *   r13 (_SDA_BASE_)  = 0x80505920  (.sdata + 0x8000)
 *   r2  (_SDA2_BASE_) = 0x80515920  (.sdata2 + 0x15320, original SN layout)
 *   r1  (stack)        = 0x805115A0
 */

OUTPUT_FORMAT("elf32-powerpc")
OUTPUT_ARCH(powerpc:common)
ENTRY(__start)

SECTIONS
{
    /* ===== Text sections ===== */

    /* .init — boot code: __start, __init_hardware, __flush_cache, etc. */
    .init 0x80003100 :
    {
        KEEP(*(.init))
    }

    /* .text — all program code */
    .text 0x800034C0 :
    {
        *(.text)
        *(.text.*)
    }

    /* ===== Data sections ===== */

    /* .ctors — C++ static constructor table */
    .ctors 0x803CA900 :
    {
        KEEP(*(.ctors))
    }

    /* .dtors — C++ static destructor table */
    .dtors 0x803CABA0 :
    {
        KEEP(*(.dtors))
    }

    /* .rodata — read-only data (string literals, const arrays, vtables) */
    .rodata 0x803CAD20 :
    {
        *(.rodata)
        *(.rodata.*)
    }

    /* .data — initialized read-write data */
    .data 0x804235E0 :
    {
        *(.data)
        *(.data.*)
    }

    /* .bss — zero-initialized data */
    .bss 0x8046E1E0 :
    {
        *(.bss)
        *(.bss.*)
        *(COMMON)
    }

    /* ===== Small data sections (r13/r2 relative) ===== */

    /* .sdata — small initialized read-write data (r13-relative) */
    .sdata 0x804FD920 :
    {
        *(.sdata)
        *(.sdata.*)
    }

    /* .sbss — small zero-initialized data (r13-relative) */
    .sbss 0x804FF6C0 :
    {
        *(.sbss)
        *(.sbss.*)
    }

    /* .sdata2 — small read-only data (r2-relative) */
    .sdata2 0x80500600 :
    {
        *(.sdata2)
        *(.sdata2.*)
    }

    /* .sbss2 — small zero-initialized read-only data (empty in this game) */
    .sbss2 0x8050158C :
    {
        *(.sbss2)
        *(.sbss2.*)
    }

    /* ===== Linker-generated symbols ===== */

    /* SDA base registers — must match values loaded in __start */
    _SDA_BASE_  = 0x80505920;  /* r13: .sdata + 0x8000 */
    _SDA2_BASE_ = 0x80515920;  /* r2:  original SN Systems value */

    /* Stack — set in __start, not by linker, but defined for reference */
    __stack_addr = 0x805115A0;
    __stack_end  = 0x80501600;  /* approximate — below .sbss2 end */

    /* BSS boundaries — used by crt0 to zero BSS */
    __bss_start = ADDR(.bss);
    __bss_end   = ADDR(.sbss2) + SIZEOF(.sbss2);

    /* Discard debug sections to keep output clean */
    /DISCARD/ :
    {
        *(.comment)
        *(.gnu.attributes)
        *(.note)
        *(.note.*)
    }
}
